{
  "expo": {
    "name": "BijliCut",
    "slug": "bijlicut",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.minhalalisorganization.bijlicut",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.minhalalisorganization.bijlicut"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#f4b400",
          "defaultChannel": "peak-hour-alerts"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "204c2f24-dd8b-4a0c-99b9-182eb42d5e1c"
      }
    },
    "owner": "minhalalis-organization"
  }
}
