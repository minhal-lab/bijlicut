{
  "expo": {
    "name": "BijliCut",
    "slug": "bijlicut",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true
    },
    "android": {},
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#f4b400",
          "defaultChannel": "peak-hour-alerts"
        }
      ]
    ]
  }
}
